# YouTube Learning Curator — Environment Variables
# Copy to .env and fill in your values

# YouTube Data API v3
YOUTUBE_API_KEY=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Clerk Authentication
CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=/sign-in
CLERK_WEBHOOK_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk Billing — Account Portal URL for upgrade links
# Dev:  https://viable-llama-18.accounts.dev/user
# Prod: https://accounts.<your-clerk-domain>/user
# Find this in Clerk Dashboard > Account Portal
CLERK_ACCOUNT_PORTAL_URL=

# App base URL (used for redirect_url construction)
APP_URL=http://localhost:3000

# Server port (default: 3000)
PORT=3000
